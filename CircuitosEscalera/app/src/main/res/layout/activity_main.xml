<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:layout_marginTop="40dp"
        android:elevation="8dp"
        app:title="Ingresa Valores"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light" />

    <ImageView
        android:id="@+id/imgCircuito"
        android:layout_width="0dp"
        android:layout_height="180dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/circuito1"
        app:layout_constraintTop_toBottomOf="@id/my_toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardInputs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/imgCircuito"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:id="@+id/gridResistencias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <EditText android:id="@+id/etR1" android:layout_width="75dp" android:layout_height="wrap_content" android:hint="R1" android:inputType="numberDecimal" android:textAlignment="center"/>
            <EditText android:id="@+id/etR4" android:layout_width="75dp" android:layout_height="wrap_content" android:hint="R4" android:inputType="numberDecimal" android:textAlignment="center"/>
            <EditText android:id="@+id/etR2" android:layout_width="75dp" android:layout_height="wrap_content" android:hint="R2" android:inputType="numberDecimal" android:textAlignment="center"/>
            <EditText android:id="@+id/etR5" android:layout_width="75dp" android:layout_height="wrap_content" android:hint="R5" android:inputType="numberDecimal" android:textAlignment="center"/>
            <EditText android:id="@+id/etR3" android:layout_width="75dp" android:layout_height="wrap_content" android:hint="R3" android:inputType="numberDecimal" android:textAlignment="center"/>
            <EditText android:id="@+id/etR6" android:layout_width="75dp" android:layout_height="wrap_content" android:hint="R6" android:inputType="numberDecimal" android:textAlignment="center"/>
        </GridLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/gridResistencias"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <EditText
                android:id="@+id/etVoltaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="V"
                android:textAlignment="center"
                android:inputType="numberDecimal"
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:textSize="18sp" />

            <Button
                android:id="@+id/btnSiguiente"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Calcular →"
                android:backgroundTint="#2196F3"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>